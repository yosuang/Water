    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@typescript/native-preview": "^7.0.0-dev.20260519.1",
    "husky": "^9.1.7"
  }
}
